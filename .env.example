DATABASE_URL="postgresql://user:password@localhost:5432/abtest?schema=public"
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_TRUST_HOST="true"
NEXTAUTH_URL="http://localhost:3000"

# 관리자 로그인 (실험 생성 등에 필요)
AUTH_ADMIN_EMAIL="admin@example.com"
AUTH_ADMIN_PASSWORD="your-secure-password"

# (선택) /admin 1차 게이트 — 팀에 공유할 단일 비밀번호. 설정 시 AUTH_SECRET 필수
# ADMIN_PASSWORD="team-shared-secret"

# 프로덕션에서 /api/debug/* 허용 시에만 true (기본 비활성)
# AUTH_DEBUG="true"

# UX Writing System — Supabase (guidelines / api_keys 테이블, 관리자 CRUD·검수 API)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-secret"

# UX Writing System — Gemini (/api/v1/ux-writing/check)
GEMINI_API_KEY="AIza..."
GEMINI_MODEL="gemini-2.5-flash"

# UX Writing API CORS — 브라우저에서 허용할 Origin 목록(쉼표). 본 서비스 URL·Figma 등
# 예: https://app.example.com,https://www.figma.com,http://localhost:3000
UX_WRITING_CORS_ORIGINS="http://localhost:3000,https://www.figma.com,https://figma.com,https://YOUR_PROJECT.vercel.app"

# Origin: null 허용(피그마 등). false 로 거부
# UX_WRITING_ALLOW_NULL_ORIGIN="true"

# Origin 없는 요청(curl 등)까지 CORS에서 거부하려면 true
# UX_WRITING_BLOCK_NO_ORIGIN="false"

# UX Writing API 레이트 리밋(메모리 기준, 인스턴스별). IP(인증 전) / API 키(인증 후)
# UX_WRITING_RATE_LIMIT_WINDOW_MS=60000
# UX_WRITING_IP_RATE_LIMIT_MAX=40
# UX_WRITING_RATE_LIMIT_MAX=60

# (선택) 월간 검수 횟수 상한 — 초과 시 403. 미설정·0 = 제한 없음. Supabase 테이블 ux_writing_usage 필요
# UX_WRITING_MAX_CHECKS_PER_MONTH=50

# Gemini 호출 타임아웃(ms), 기본 90000
# UX_WRITING_AI_TIMEOUT_MS=90000

# (선택) 레거시 단일 키 — DB api_keys 매칭 실패 시에만 허용(마이그레이션·비상)
# UX_CHECK_API_KEY=""
