{
  "name": "hanatour-ux-writing-figma-plugin",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc --noEmit -p tsconfig.json && esbuild src/code.ts --bundle --outfile=dist/code.js --target=es2017 && node -e \"require('fs').mkdirSync('dist',{recursive:true});require('fs').copyFileSync('src/ui.html','dist/ui.html')\"",
    "watch": "esbuild src/code.ts --bundle --outfile=dist/code.js --target=es2017 --watch"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.100.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.3"
  }
}
